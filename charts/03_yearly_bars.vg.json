{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 380,
  "background": "transparent",
  "data": {
    "url": "data/yearly_events.csv"
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": null,
      "axis": {
        "labelFontSize": 12,
        "labelAngle": 0
      }
    }
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusTopLeft": 3,
        "cornerRadiusTopRight": 3
      },
      "encoding": {
        "y": {
          "field": "events",
          "type": "quantitative",
          "title": "New bushfire events",
          "scale": {
            "domain": [
              0,
              50
            ]
          },
          "axis": {
            "labelFontSize": 11,
            "titleFontSize": 12,
            "grid": true,
            "gridOpacity": 0.3
          }
        },
        "color": {
          "field": "events",
          "type": "quantitative",
          "scale": {
            "type": "threshold",
            "domain": [
              10,
              20,
              30,
              40
            ],
            "range": [
              "#f4b78c",
              "#e07a4b",
              "#c0392b",
              "#7a1d11",
              "#4a0f08"
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "events",
            "type": "quantitative",
            "title": "New events"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "bottom",
        "dy": -4,
        "fontSize": 10,
        "color": "#444"
      },
      "encoding": {
        "y": {
          "field": "events",
          "type": "quantitative"
        },
        "text": {
          "field": "events",
          "type": "quantitative"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.annotation != '' && datum.annotation != null"
        }
      ],
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "bottom",
        "dy": -22,
        "fontSize": 11,
        "fontWeight": "bold",
        "fontStyle": "italic",
        "color": "#7a1d11"
      },
      "encoding": {
        "y": {
          "field": "events",
          "type": "quantitative"
        },
        "text": {
          "field": "annotation",
          "type": "nominal"
        }
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#555",
        "strokeDash": [
          4,
          4
        ],
        "strokeWidth": 1.5,
        "interpolate": "step"
      },
      "encoding": {
        "y": {
          "field": "avg",
          "type": "quantitative"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.year == 2026"
        }
      ],
      "mark": {
        "type": "text",
        "align": "right",
        "baseline": "bottom",
        "dx": -4,
        "dy": -4,
        "fontSize": 10,
        "fontStyle": "italic",
        "color": "#555"
      },
      "encoding": {
        "y": {
          "field": "avg",
          "type": "quantitative"
        },
        "text": {
          "value": "average: 14.5 events/year"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "domain": false,
      "ticks": false
    }
  }
}