{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 360,
  "background": "transparent",
  "data": {
    "url": "data/disaster_share.csv"
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": null,
      "axis": {
        "labelFontSize": 11,
        "labelAngle": 0
      }
    }
  },
  "layer": [
    {
      "mark": {
        "type": "area",
        "color": "#e07a4b",
        "opacity": 0.25,
        "interpolate": "monotone"
      },
      "encoding": {
        "y": {
          "field": "bushfire_pct",
          "type": "quantitative",
          "title": "Bushfire share of all disaster activations (%)",
          "scale": {
            "domain": [
              0,
              65
            ]
          },
          "axis": {
            "labelFontSize": 11,
            "titleFontSize": 12,
            "grid": true,
            "gridOpacity": 0.2
          }
        }
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#7a1d11",
        "strokeWidth": 2.5,
        "interpolate": "monotone"
      },
      "encoding": {
        "y": {
          "field": "bushfire_pct",
          "type": "quantitative"
        }
      }
    },
    {
      "mark": {
        "type": "circle",
        "size": 70,
        "color": "#7a1d11"
      },
      "encoding": {
        "y": {
          "field": "bushfire_pct",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "bushfire_pct",
            "type": "quantitative",
            "title": "Bushfire share (%)"
          },
          {
            "field": "bushfire",
            "type": "quantitative",
            "title": "Bushfire activations"
          },
          {
            "field": "total",
            "type": "quantitative",
            "title": "All disaster activations"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.annotation != '' && datum.annotation != null"
        }
      ],
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "bottom",
        "dy": -10,
        "fontSize": 11,
        "fontWeight": "bold",
        "fontStyle": "italic",
        "color": "#7a1d11"
      },
      "encoding": {
        "y": {
          "field": "bushfire_pct",
          "type": "quantitative"
        },
        "text": {
          "field": "annotation",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "domain": false,
      "ticks": false,
      "labelPadding": 6
    }
  }
}