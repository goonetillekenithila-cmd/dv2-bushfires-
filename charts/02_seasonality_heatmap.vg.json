{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 380,
  "background": "transparent",
  "data": {
    "url": "data/heatmap_data.csv"
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": null,
      "axis": {
        "labelFontSize": 12,
        "labelAngle": 0
      }
    },
    "y": {
      "field": "date",
      "timeUnit": "month",
      "type": "ordinal",
      "title": null,
      "axis": {
        "labelFontSize": 12,
        "format": "%b"
      }
    }
  },
  "layer": [
    {
      "mark": {
        "type": "rect",
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "color": {
          "field": "events",
          "type": "quantitative",
          "scale": {
            "type": "threshold",
            "domain": [
              1,
              3,
              6,
              9
            ],
            "range": [
              "#f5ebe0",
              "#f4b78c",
              "#e07a4b",
              "#c0392b",
              "#7a1d11"
            ]
          },
          "legend": {
            "title": "New bushfire events",
            "orient": "right",
            "labelFontSize": 11,
            "titleFontSize": 12,
            "titleLimit": 220
          }
        },
        "tooltip": [
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "date",
            "timeUnit": "month",
            "type": "ordinal",
            "title": "Month",
            "format": "%B"
          },
          {
            "field": "events",
            "type": "quantitative",
            "title": "New events"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.annotation != '' && datum.annotation != null"
        }
      ],
      "mark": {
        "type": "text",
        "fontSize": 11,
        "fontWeight": "bold",
        "fontStyle": "italic",
        "color": "#222",
        "align": "left",
        "dx": 14
      },
      "encoding": {
        "text": {
          "field": "annotation",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "domain": false,
      "ticks": false,
      "labelPadding": 8
    }
  }
}