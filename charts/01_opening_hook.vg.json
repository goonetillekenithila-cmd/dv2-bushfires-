{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 560,
  "background": "transparent",
  "projection": {
    "type": "mercator",
    "center": [
      134,
      -29.5
    ],
    "scale": 780
  },
  "params": [
    {
      "name": "year_select",
      "value": 2019,
      "bind": {
        "input": "range",
        "min": 2009,
        "max": 2026,
        "step": 1,
        "name": "Year:  "
      }
    }
  ],
  "layer": [
    {
      "data": {
        "url": "data/states.topo.json",
        "format": {
          "type": "topojson",
          "feature": "states"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#ececec",
        "stroke": "#ffffff",
        "strokeWidth": 1.2
      }
    },
    {
      "data": {
        "url": "data/state_year_activations.csv"
      },
      "transform": [
        {
          "filter": "datum.year == year_select"
        },
        {
          "lookup": "state",
          "from": {
            "data": {
              "url": "data/states.topo.json",
              "format": {
                "type": "topojson",
                "feature": "states"
              }
            },
            "key": "properties.state"
          },
          "as": "geo"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 1.2
      },
      "encoding": {
        "shape": {
          "field": "geo",
          "type": "geojson"
        },
        "color": {
          "field": "activations",
          "type": "quantitative",
          "scale": {
            "type": "threshold",
            "domain": [
              1,
              10,
              30,
              70
            ],
            "range": [
              "#fbe7d4",
              "#f4b78c",
              "#e07a4b",
              "#c0392b",
              "#7a1d11"
            ]
          },
          "legend": {
            "title": "Activations in year",
            "orient": "right",
            "labelFontSize": 11,
            "titleFontSize": 12,
            "titleLimit": 220
          }
        },
        "tooltip": [
          {
            "field": "state",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "activations",
            "type": "quantitative",
            "title": "Activations"
          },
          {
            "field": "year",
            "type": "quantitative",
            "title": "Year"
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/state_labels.csv"
      },
      "mark": {
        "type": "text",
        "fontSize": 13,
        "fontWeight": "bold",
        "fill": "#222"
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "text": {
          "field": "abbr",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    }
  }
}